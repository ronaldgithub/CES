<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:CES.UI.Converters"
             x:Class="CES.UI.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <converters:OperationColorConverter x:Key="OpColorConverter" />
    </Application.Resources>
</Application>
