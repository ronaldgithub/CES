<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CES.UI.ViewModels"
        xmlns:views="using:CES.UI.Views"
        x:Class="CES.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SQL Server 2025 · CES Monitor"
        Width="1024" Height="720"
        MinWidth="800" MinHeight="500"
        Background="#111827">

    <TabControl Background="#111827">
        <TabControl.Styles>
            <Style Selector="TabItem">
                <Setter Property="Background" Value="#1F2937"/>
                <Setter Property="Foreground" Value="#D1D5DB"/>
                <Setter Property="FontSize" Value="12.5"/>
            </Style>
            <Style Selector="TabItem:selected">
                <Setter Property="Background" Value="#1E3A5F"/>
                <Setter Property="Foreground" Value="#F9FAFB"/>
            </Style>
        </TabControl.Styles>

        <TabItem Header="Live Feed">
            <views:LiveFeedView DataContext="{Binding}"/>
        </TabItem>
        <TabItem Header="Idempotency &amp; Offsets">
            <views:IdempotencyView DataContext="{Binding IdempotencyTab}"/>
        </TabItem>
        <TabItem Header="Two Consumers">
            <views:TwoConsumersView DataContext="{Binding TwoConsumersTab}"/>
        </TabItem>
        <TabItem Header="Two Consumers (Live)">
            <views:TwoConsumersLiveView DataContext="{Binding TwoConsumersLiveTab}"/>
        </TabItem>
        <TabItem Header="Parallel Partitions">
            <views:ParallelPartitionsView DataContext="{Binding ParallelPartitionsTab}"/>
        </TabItem>
        <TabItem Header="Multi-Table Routing">
            <views:MultiTableView DataContext="{Binding MultiTableTab}"/>
        </TabItem>
        <TabItem Header="Batching">
            <views:BatchingView DataContext="{Binding BatchingTab}"/>
        </TabItem>
    </TabControl>
</Window>
