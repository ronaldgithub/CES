<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CES.UI.ViewModels"
             x:Class="CES.UI.Views.BatchingLiveView"
             x:DataType="vm:BatchingLiveTabViewModel">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Background="#111827">

        <!-- ── Action bar ── -->
        <Border Grid.Row="0" Background="#1F2937" Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Start" Command="{Binding StartCommand}"/>
                <Button Content="Stop" Command="{Binding StopCommand}"/>
                <Button Content="Add Next Event to Batch" Command="{Binding AddNextEventToBatchCommand}"/>
                <Button Content="Commit Batch" Command="{Binding CommitBatchCommand}"/>
                <Button Content="Simulate Crash Mid-Batch" Command="{Binding SimulateCrashMidBatchCommand}"/>
                <Button Content="Reset DB" Command="{Binding ResetDbCommand}"/>
                <TextBlock Text="{Binding Status}"
                           Foreground="#6B7280"
                           FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Queue / batch / ledger columns ── -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="16">

            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="4">
                <TextBlock Text="{Binding IncomingQueue.Count, StringFormat='Incoming Queue ({0})'}" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding IncomingQueue}" Background="#1F2937" BorderThickness="0" MaxHeight="260">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" Foreground="#D1D5DB" FontFamily="Consolas,Menlo,monospace" FontSize="12" Padding="4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="8,0,8,0" Spacing="4">
                <TextBlock Text="{Binding CurrentBatch.Count, StringFormat='Current Batch ({0} / 5)'}" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding CurrentBatch}" Background="#1F2937" BorderThickness="0" MaxHeight="260">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" Foreground="#93C5FD" FontFamily="Consolas,Menlo,monospace" FontSize="12" Padding="4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4">
                <TextBlock Text="{Binding Ledger.Count, StringFormat='ces_ledger ({0} rows) — CES_Batching'}" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding Ledger}" Background="#1F2937" BorderThickness="0" MaxHeight="230">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SequenceNumber, StringFormat='seq {0}'}" Foreground="#6EE7B7" FontFamily="Consolas,Menlo,monospace" FontSize="12" Padding="4"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="{Binding OffsetSummary}" Foreground="#6EE7B7" FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                <TextBlock Text="{Binding TargetTableSummary}" Foreground="#FCA5A5" FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
            </StackPanel>

        </Grid>

        <!-- ── Log ── -->
        <StackPanel Grid.Row="2" Margin="16,0,16,12">
            <TextBlock Text="Log" Foreground="#6B7280" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ListBox ItemsSource="{Binding Log}" Background="#111827" BorderThickness="0" MaxHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#D1D5DB" FontFamily="Consolas,Menlo,monospace" FontSize="12" Padding="0,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

    </Grid>
</UserControl>
